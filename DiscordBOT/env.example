# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_bot_client_id_here

# Guild ID for guild-based commands (faster registration during dev)
DISCORD_GUILD_ID=your_guild_id_here
# Role ID allowed to use admin commands (addlicense, revoke, renew)
DISCORD_ADMIN_ROLE_ID=your_admin_role_id_here

# Firebase service account JSON (paste the entire JSON as a single line)
# Get this from Firebase Console > Project Settings > Service Accounts > Generate New Private Key
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
